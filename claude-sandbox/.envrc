# claude-sandbox/.envrc
# Bind-mounted RO into ~claude/workspace/.envrc by modules/system/claude.nix.
# Direnv (enabled system-wide by modules/system/caveman.nix's programs.direnv)
# picks this up on `cd ~/workspace` and activates the pinned devShell — no
# `nix develop` step needed.
#
# Claude must run `direnv allow` ONCE per content change. nimbus can bump the
# toolchain freely; claude just re-allows on next entry.
#
# Guard: this .envrc is the source side of the bind mount, so it also exists
# at ~/.config/nixos/claude-sandbox/.envrc on the host. If nimbus cd's there,
# direnv would otherwise try to load it and scaffold a `.direnv/` in the
# source repo. Bail early when not running as claude.

if [ "$USER" != "claude" ]; then
  log_status "skipping claude sandbox .envrc (USER=$USER, not claude)"
  return 0
fi

use flake ./claude-sandbox
