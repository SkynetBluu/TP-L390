#!/usr/bin/env bash
# promote-claude-home
# Bundle ~/.claude/{CLAUDE.md, settings.json, memory/} so they can be
# overlaid onto ~/.config/nixos/claude-home/. The allowlist deliberately
# excludes credentials, sessions, history, cache, plans, file-history,
# shell-snapshots, paste-cache — none of those belong in the baseline.
#
# Direction: sandbox → host. The sandbox files replace the host files.

set -euo pipefail

SOURCE=/home/claude/.claude
BUNDLE_PARENT=/home/claude/workspace/projects
STAMP=$(date +%Y-%m-%d-%H%M%S)
BUNDLE_NAME=promote-claude-home-$STAMP
BUNDLE_DIR=$BUNDLE_PARENT/$BUNDLE_NAME

ITEMS=(CLAUDE.md settings.json memory skills)

mkdir -p "$BUNDLE_DIR"

PRESENT=()
for item in "${ITEMS[@]}"; do
  src=$SOURCE/$item
  if [ ! -e "$src" ]; then
    echo "promote-claude-home: $item not present in ~/.claude/ — skipping" >&2
    continue
  fi
  cp -rT "$src" "$BUNDLE_DIR/$item"
  PRESENT+=("$item")
done

if [ "${#PRESENT[@]}" -eq 0 ]; then
  echo "promote-claude-home: nothing to bundle" >&2
  exit 1
fi

chmod -R go+rX "$BUNDLE_DIR"

cat <<EOF

Bundle staged at: ~/claude-projects/$BUNDLE_NAME
Items: ${PRESENT[*]}

Run from a nimbus host shell:

  cp -rT ~/claude-projects/$BUNDLE_NAME ~/.config/nixos/claude-home/ && \\
    git -C ~/.config/nixos status --short claude-home/

Then review with 'git -C ~/.config/nixos diff claude-home/' and commit when satisfied.
EOF

# Prune: keep the 5 most-recent promote-claude-home-* dirs in BUNDLE_PARENT.
# Timestamps sort lexically, so the bundle we just wrote (latest stamp) is
# always position 1 and survives.
find "$BUNDLE_PARENT" -maxdepth 1 -type d -name 'promote-claude-home-*' 2>/dev/null \
  | sort -r | tail -n +6 | xargs -r rm -rf
