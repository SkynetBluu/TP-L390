# caveman-sandbox/.envrc
# Bind-mounted RO into ~caveman/workspace/.envrc by modules/system/caveman.nix.
# Direnv (enabled system-wide via programs.direnv) picks this up on `cd` and
# activates the pinned devShell — no `nix develop` step needed.
#
# `use flake` resolves the flake at the path next to this .envrc — namely the
# caveman-sandbox/ bind mount alongside it in ~/workspace.
#
# Caveman must run `direnv allow` ONCE per content change (direnv refuses
# unfamiliar .envrc files until explicitly trusted). nimbus can bump the
# toolchain freely; caveman just re-allows on next entry.
#
# Guard: this .envrc is the source side of the bind mount, so it also exists
# at ~/.config/nixos/caveman-sandbox/.envrc on the host. If nimbus cd's there,
# direnv would otherwise try to load this and scaffold a `.direnv/` cache in
# the source repo. Bail early when not running as caveman.

if [ "$USER" != "caveman" ]; then
  log_status "skipping caveman sandbox .envrc (USER=$USER, not caveman)"
  return 0
fi

use flake ./caveman-sandbox
